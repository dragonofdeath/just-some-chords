---
import Layout from "../../../layouts/Layout.astro";
import SongEditor from "../../../components/SongEditor";
import { auth } from "@wix/essentials";
import { items } from "@wix/data";

// A song opened from a shared playlist — same rules as /s/: the elevated read
// is gated by the playlist's shareId AND the song must actually be in that
// playlist. The full editor opens on an unsaved copy (no _id / shareId passed,
// so a save can only ever fork into the visitor's own songbook).
const { shareId, songId } = Astro.params;

let song: any = null;
if (
  shareId && /^[A-Za-z0-9-]{16,64}$/.test(shareId) &&
  songId && /^[A-Za-z0-9-]{1,64}$/.test(songId)
) {
  try {
    const elevatedQuery = auth.elevate(items.query);
    const pres = await elevatedQuery("playlists").eq("shareId", shareId).limit(1).find();
    const playlist: any = pres.items[0] ?? null;
    const ids: string[] = Array.isArray(playlist?.songIds?.list) ? playlist.songIds.list : [];
    if (ids.includes(songId)) {
      const sres = await elevatedQuery("songs").eq("_id", songId).limit(1).find();
      song = sres.items[0] ?? null;
    }
  } catch {
    song = null;
  }
}

const initialSong = song
  ? {
      title: song.title ?? "Untitled",
      songKey: song.songKey ?? "G",
      bpm: song.bpm ?? 84,
      timeSignature: song.timeSignature ?? "4/4",
      // raw v1 or v2 — the editor migrates on load
      sections: song.sections ?? null,
    }
  : null;
---

<Layout title={song ? `${song.title} — Just Some Chords` : "Shared song — Just Some Chords"}>
  {initialSong ? (
    <SongEditor
      client:only="react"
      songId="new"
      source="shared"
      initialSong={initialSong}
      backTo={`/p/${shareId}`}
    />
  ) : (
    <main class="editor">
      <div class="player-error">
        <p>This song isn't in a shared playlist (or the link was revoked).</p>
        <a class="cta" href="/">Make your own songbook</a>
      </div>
    </main>
  )}
</Layout>
