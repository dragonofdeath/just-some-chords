---
interface Props {
  title?: string;
}
const { title = "Just Some Chords" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content="Write songs on a circle of fifths — tap chords, build sections, save your songbook." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#F2F1E9" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Chords" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --paper: #f2f1e9;
    --paper-raised: #fbfaf4;
    --ink: #26302b;
    --ink-soft: #5b665f;
    --green: #38664f;
    --green-deep: #26433a;
    --rule: #d9d7c8;
    --rule-soft: #e4e2d5;
    --wedge-in: #dce5d6;
    --wedge-in-minor: #e4eadd;
    --wedge-out: #ecebe0;
    --wedge-out-text: #9aa095;
    --serif: "Iowan Old Style", Palatino, Georgia, serif;
    --ui: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
  }

  * {
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
  }

  /* focus rings only for keyboard navigation — never for taps */
  :focus:not(:focus-visible) {
    outline: none;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    background: var(--paper);
    color: var(--ink);
    font-family: var(--ui);
    -webkit-font-smoothing: antialiased;
  }

  .shell {
    max-width: 430px;
    margin: 0 auto;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    padding: env(safe-area-inset-top) 0 env(safe-area-inset-bottom);
  }

  button {
    font-family: var(--ui);
  }

  a:focus-visible,
  button:focus-visible,
  input:focus-visible,
  .wedge:focus-visible {
    outline: 2px solid var(--green);
    outline-offset: 2px;
  }

  /* ---------- landing ---------- */
  .landing {
    justify-content: center;
    text-align: center;
    padding: 32px 28px;
  }
  .landing .brand {
    font-family: var(--serif);
    font-size: 15px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--green);
    margin: 0 0 18px;
  }
  .landing h1 {
    font-family: var(--serif);
    font-weight: 600;
    font-size: clamp(34px, 9vw, 44px);
    line-height: 1.12;
    margin: 0 0 14px;
    text-wrap: balance;
  }
  .landing .lede {
    color: var(--ink-soft);
    font-size: 16.5px;
    line-height: 1.55;
    margin: 0 auto 30px;
    max-width: 34ch;
  }
  .landing .wheel-motif {
    margin: 0 auto 34px;
    display: block;
  }
  .cta {
    display: inline-block;
    background: var(--green);
    color: var(--paper-raised);
    font-size: 17px;
    font-weight: 600;
    text-decoration: none;
    border-radius: 999px;
    padding: 15px 34px;
  }
  .cta:active {
    background: var(--green-deep);
  }
  .landing .fine {
    margin-top: 16px;
    font-size: 13px;
    color: var(--ink-soft);
    line-height: 1.7;
  }
  .fine-link {
    color: var(--green);
    font-weight: 600;
  }

  /* ---------- song list ---------- */
  .list-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 26px 22px 8px;
  }
  .list-head h1 {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 28px;
    margin: 0;
  }
  .whoami {
    padding: 0 22px 14px;
    font-size: 13px;
    color: var(--ink-soft);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }
  .logout-btn {
    background: none;
    border: none;
    color: var(--green);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    padding: 4px 0;
  }
  .song-list {
    list-style: none;
    margin: 0;
    padding: 4px 16px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .song-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    background: var(--paper-raised);
    border: 1px solid var(--rule);
    border-radius: 14px;
    padding: 14px 16px;
    text-decoration: none;
    color: var(--ink);
    box-shadow: 0 1px 0 rgba(38, 48, 43, 0.06);
  }
  .song-card .s-title {
    font-family: var(--serif);
    font-size: 19px;
    font-weight: 600;
    margin: 0 0 2px;
  }
  .song-card .s-sub {
    font-size: 12.5px;
    color: var(--ink-soft);
  }
  .song-card .s-key {
    flex-shrink: 0;
    background: var(--green);
    color: var(--paper-raised);
    font-size: 12.5px;
    font-weight: 700;
    border-radius: 999px;
    padding: 6px 12px;
  }
  .empty-state {
    margin: 40px 28px;
    text-align: center;
    color: var(--ink-soft);
    font-size: 15px;
    line-height: 1.6;
  }
  .new-song-row {
    padding: 0 16px 30px;
    margin-top: auto;
  }
  .new-song {
    display: block;
    text-align: center;
    background: var(--green);
    color: var(--paper-raised);
    font-size: 16.5px;
    font-weight: 600;
    text-decoration: none;
    border-radius: 999px;
    padding: 15px;
  }
  .load-error {
    margin: 16px 22px;
    padding: 12px 16px;
    border: 1px solid var(--rule);
    border-radius: 10px;
    background: var(--paper-raised);
    color: var(--ink-soft);
    font-size: 14px;
  }

  /* ---------- editor ---------- */
  .editor {
    display: flex;
    flex-direction: column;
    height: 100dvh;
    overflow: hidden;
    max-width: 430px;
    margin: 0 auto;
  }
  .ed-head {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 16px 16px 4px;
  }
  .back {
    color: var(--ink);
    text-decoration: none;
    font-size: 30px;
    line-height: 1;
    padding: 0 8px 4px 2px;
  }
  .title-input {
    flex: 1;
    min-width: 0;
    font-family: var(--serif);
    font-size: 20px;
    font-weight: 600;
    color: var(--ink);
    background: transparent;
    border: none;
    border-bottom: 1px dashed transparent;
    padding: 4px 2px;
  }
  .title-input:focus {
    border-bottom-color: var(--rule);
    outline: none;
  }
  .save-btn {
    flex-shrink: 0;
    background: var(--green);
    color: var(--paper-raised);
    border: none;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 700;
    padding: 9px 18px;
    cursor: pointer;
  }
  .save-btn:disabled {
    background: var(--rule);
    color: var(--ink-soft);
    cursor: default;
  }
  .hist-btn {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid var(--rule);
    background: var(--paper-raised);
    color: var(--ink);
    font-size: 15px;
    line-height: 1;
    cursor: pointer;
    padding: 0;
  }
  .hist-btn:disabled {
    opacity: 0.35;
    cursor: default;
  }
  .share-btn {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--rule);
    background: var(--paper-raised);
    color: var(--ink);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .share-note {
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0 0 16px;
  }
  .share-url-row {
    display: flex;
    align-items: center;
    gap: 10px;
    border: 1px solid var(--rule);
    border-radius: 10px;
    background: var(--paper);
    padding: 10px 12px;
    margin-bottom: 16px;
  }
  .share-url {
    flex: 1;
    min-width: 0;
    font-size: 12.5px;
    color: var(--ink);
    word-break: break-all;
    user-select: all;
  }
  .save-error {
    margin: 6px 16px 0;
    font-size: 13px;
    color: #8c3b2e;
  }
  .shared-note {
    margin: 4px 18px 0;
    font-size: 12px;
    font-weight: 600;
    color: var(--green);
  }

  .key-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    padding: 8px 0 0;
  }
  .key-pill {
    background: var(--ink);
    color: var(--paper);
    font-size: 13px;
    font-weight: 700;
    border-radius: 999px;
    padding: 7px 16px;
  }
  .key-arrow {
    background: var(--paper-raised);
    border: 1px solid var(--rule);
    border-radius: 999px;
    width: 34px;
    height: 34px;
    font-size: 15px;
    color: var(--ink);
    cursor: pointer;
  }

  .wheel-toggle {
    font-size: 12px;
  }
  .compact-row {
    display: flex;
    gap: 8px;
    justify-content: center;
    padding: 10px 14px 2px;
  }
  .compact-chord {
    flex: 1;
    max-width: 62px;
    border: 1px solid var(--rule);
    background: var(--paper-raised);
    color: var(--ink);
    border-radius: 12px;
    padding: 9px 0 7px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
    box-shadow: 0 1px 0 rgba(38, 48, 43, 0.07);
    touch-action: manipulation;
    -webkit-user-select: none;
    user-select: none;
  }
  .compact-chord:active {
    transform: scale(0.94);
  }
  .compact-chord .c-name {
    font-family: var(--serif);
    font-size: 17px;
    font-weight: 700;
  }
  .compact-chord .c-roman {
    font-size: 10px;
    color: var(--green-deep);
    font-weight: 700;
  }
  .wheelbox {
    display: flex;
    justify-content: center;
    padding: 8px 0 0;
  }
  .wheelbox svg {
    touch-action: manipulation;
    -webkit-user-select: none;
    user-select: none;
  }
  .wedge:focus {
    outline: none;
  }
  .wedge:focus-visible {
    outline: 2px solid var(--green);
  }
  .wedge {
    cursor: pointer;
  }
  .wedge-in.wedge-maj {
    fill: var(--wedge-in);
    stroke: var(--green);
    stroke-width: 1.3;
  }
  .wedge-in.wedge-min {
    fill: var(--wedge-in-minor);
    stroke: var(--green);
    stroke-width: 1.3;
  }
  .wedge-out {
    fill: var(--wedge-out);
    stroke: var(--paper);
    stroke-width: 2;
  }
  .wedge-label {
    font-family: var(--serif);
  }
  .label-maj {
    font-size: 16.5px;
  }
  .label-min {
    font-size: 13px;
  }
  .label-in {
    fill: var(--green-deep);
    font-weight: 700;
  }
  .label-out {
    fill: var(--wedge-out-text);
  }
  .hub {
    fill: var(--green);
  }
  .hub-key {
    fill: var(--paper-raised);
    font-family: var(--serif);
    font-size: 21px;
    font-weight: 700;
  }
  .hub-sub {
    fill: var(--paper-raised);
    font-size: 10px;
    font-weight: 600;
    opacity: 0.65;
    letter-spacing: 0.1em;
  }

  /* all song parts — cardless, stacked and scrollable */
  .sections-scroll {
    flex: 1;
    overflow-y: auto;
    padding: 8px 18px 14px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-height: 120px;
  }
  .section-block {
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
  }
  .sb-active .sb-name {
    color: var(--green);
  }
  .line-row {
    padding: 3px 0 3px 6px;
    border-left: 2px solid transparent;
    border-radius: 2px;
  }
  .line-active {
    border-left-color: var(--green);
  }
  .line-badge {
    align-self: center;
    border: 1px solid var(--rule);
    background: transparent;
    color: var(--ink-soft);
    font-size: 11.5px;
    font-weight: 700;
    border-radius: 999px;
    padding: 4px 10px;
    margin-left: 8px;
    cursor: pointer;
    font-variant-numeric: tabular-nums;
  }
  .line-badge-on {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--paper);
  }
  .sb-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 4px;
  }
  .sb-name {
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--ink-soft);
  }
  .sb-meta {
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
    font-weight: 600;
  }
  .sb-side {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .sb-title-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .sb-repeat {
    background: var(--ink);
    color: var(--paper);
    font-size: 11.5px;
    font-weight: 700;
    border-radius: 999px;
    padding: 3px 9px;
    font-variant-numeric: tabular-nums;
  }
  .sb-more {
    border: none;
    background: transparent;
    color: var(--ink-soft);
    font-size: 20px;
    line-height: 1;
    padding: 2px 6px;
    cursor: pointer;
    border-radius: 8px;
  }
  .sb-more:active {
    background: var(--rule-soft);
  }
  .sb-active .sb-meta {
    color: var(--green);
  }
  .add-section {
    border: 1px dashed var(--rule);
    background: transparent;
    color: var(--green);
    font-size: 14.5px;
    font-weight: 600;
    border-radius: 12px;
    padding: 12px;
    cursor: pointer;
  }
  /* chord line — barlines instead of cards, like a lead sheet */
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 0;
    align-content: flex-start;
  }
  .chip {
    border: none;
    border-left: 2px solid var(--rule);
    border-radius: 0;
    background: transparent;
    color: var(--ink);
    padding: 3px 16px 3px 9px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    line-height: 1.12;
    /* vertical swipes scroll the list; horizontal drags select a range */
    touch-action: pan-y;
    -webkit-user-select: none;
    user-select: none;
  }
  .chip:active {
    transform: scale(0.96);
  }
  .chip .c-name {
    font-family: var(--serif);
    font-size: 20px;
    font-weight: 700;
  }
  .chip .c-roman {
    font-size: 10px;
    color: var(--ink-soft);
    font-weight: 600;
  }
  .chip-selected {
    background: var(--wedge-in);
    border-left-color: var(--green);
    border-radius: 0 8px 8px 0;
  }
  .chip-selected .c-roman {
    color: var(--green-deep);
  }
  .chip-playing .c-name {
    color: var(--green);
  }
  .chip-playing {
    border-left-color: var(--green);
  }
  .chips .empty {
    font-size: 13px;
    color: var(--ink-soft);
    padding: 6px 0;
  }

  /* measure edit strip — chord work stays inline so the wheel is never covered */
  .edit-strip {
    border-top: 1px solid var(--rule-soft);
    background: var(--paper-raised);
    padding: 8px 12px 7px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .strip-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .strip-scroll {
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .strip-scroll::-webkit-scrollbar {
    display: none;
  }
  .strip-slot {
    border: 1px solid var(--rule);
    background: var(--paper);
    color: var(--ink);
    font-family: var(--serif);
    font-size: 15px;
    font-weight: 700;
    border-radius: 8px;
    padding: 6px 12px;
    cursor: pointer;
    flex-shrink: 0;
  }
  .strip-slot-active {
    background: var(--green);
    border-color: var(--green);
    color: var(--paper-raised);
  }
  .strip-div {
    width: 1px;
    align-self: stretch;
    background: var(--rule);
    flex-shrink: 0;
    margin: 2px;
  }
  .strip-mini {
    border: 1px solid var(--rule);
    background: var(--paper);
    color: var(--ink-soft);
    font-size: 12.5px;
    font-weight: 700;
    border-radius: 8px;
    width: 30px;
    height: 30px;
    cursor: pointer;
    flex-shrink: 0;
    padding: 0;
  }
  .strip-mini-active {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--paper);
  }
  .strip-to {
    width: auto;
    padding: 0 12px;
    font-style: italic;
  }
  .strip-close {
    margin-left: auto;
  }
  .strip-pill {
    border: 1px solid var(--rule);
    background: var(--paper);
    color: var(--ink);
    font-family: var(--serif);
    font-size: 13.5px;
    border-radius: 999px;
    padding: 5px 12px;
    cursor: pointer;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .strip-pill-active {
    background: var(--green);
    border-color: var(--green);
    color: var(--paper-raised);
  }
  .strip-hint {
    font-size: 12px;
    color: var(--ink-soft);
    padding: 5px 2px;
    white-space: nowrap;
  }

  /* move mode */
  .drop-mark {
    width: 16px;
    align-self: stretch;
    min-height: 40px;
    margin: 1px 0;
    border: 1px dashed var(--green);
    border-radius: 6px;
    background: transparent;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
  }
  .drop-hot {
    background: var(--wedge-in);
    border-style: solid;
    border-width: 2px;
  }
  .chip-moving {
    opacity: 0.35;
  }

  /* split-measure grid */
  .split-grid {
    display: flex;
    gap: 0;
    margin: 4px 0 10px;
    border: 1px solid var(--rule);
    border-radius: 10px;
    overflow: hidden;
    height: 52px;
  }
  .split-cell {
    flex: 1;
    border: none;
    border-left: 1px solid var(--rule-soft);
    background: var(--paper);
    cursor: pointer;
    padding: 0;
    min-width: 0;
  }
  .split-cell:first-child {
    border-left: none;
  }
  .split-alt {
    background: var(--wedge-in);
  }
  .split-beat {
    border-left: 2px solid var(--ink-soft);
  }
  .split-beat:first-child {
    border-left: none;
  }
  .split-bound {
    border-left: 3px solid var(--green);
  }

  /* selection toolbar */
  .sel-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 9px 18px;
    border-top: 1px solid var(--rule-soft);
    background: var(--paper-raised);
  }
  .sel-info {
    flex: 1;
    min-width: 0;
    font-size: 12.5px;
    font-weight: 600;
    color: var(--ink-soft);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .sel-edit {
    border: none;
    background: var(--green);
    color: var(--paper-raised);
    font-size: 13px;
    font-weight: 700;
    border-radius: 999px;
    padding: 7px 15px;
    cursor: pointer;
    flex-shrink: 0;
  }
  .sel-clear {
    border: 1px solid var(--rule);
    background: transparent;
    color: var(--ink-soft);
    font-size: 13px;
    border-radius: 50%;
    width: 30px;
    height: 30px;
    cursor: pointer;
    flex-shrink: 0;
  }

  .tabs {
    display: flex;
    gap: 8px;
    padding: 10px 20px 0;
    flex-wrap: wrap;
  }
  .tab {
    border: none;
    background: transparent;
    font-size: 13.5px;
    font-weight: 600;
    padding: 8px 14px;
    border-radius: 999px;
    color: var(--ink);
    opacity: 0.6;
    cursor: pointer;
  }
  .tab-active {
    background: var(--green);
    color: var(--paper-raised);
    opacity: 1;
  }
  .tab-add {
    font-size: 16px;
    padding: 8px 12px;
  }

  .transport {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 20px calc(18px + env(safe-area-inset-bottom));
    border-top: 1px solid var(--rule-soft);
    background: var(--paper);
  }
  .metro-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--rule);
    background: var(--paper-raised);
    color: var(--ink-soft);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .metro-on {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--paper);
  }
  .countin-label {
